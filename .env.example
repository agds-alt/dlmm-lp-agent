# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here
SOLANA_NETWORK=mainnet-beta

# Wallet Configuration
WALLET_PRIVATE_KEY=your_base58_private_key_here

# Strategy Configuration
STARTING_CAPITAL=50
MAX_POSITIONS=3
TARGET_DAILY_GAIN=20
MAX_LOSS_PERCENT=10
MAX_IL_PERCENT=10
REBALANCE_FREQUENCY=6

# Token Filters
MIN_TOKEN_AGE_DAYS=3
MAX_TOKEN_AGE_DAYS=30
MIN_DAILY_VOLUME=50000
MAX_DAILY_VOLUME=500000
MIN_LIQUIDITY=10000

# Operation Mode
MODE=manual_approve  # Options: full_auto, manual_approve

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Safety
PAPER_TRADING=true  # Set to false for real trading
DRY_RUN=true
